{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agrifeed Trazabilidad",
  "version": "0.2.7",
  "identifier": "com.agrifeed.trazabilidad",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agrifeed - Sistema de Trazabilidad",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": [
          "Spanish",
          "English"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGQURGREZDNUM0MjdCOTIKUldTU2UwSmMvUDJ0djlRU2pQeDM4cHhtaWxJdEdSVEZsREpWdjdwWUVKUEZXZUhydmR5ZXVQRVQK",
      "endpoints": [
        "https://github.com/senafe08-hub/agrifeed-trazabilidad/releases/latest/download/latest.json"
      ]
    }
  }
}